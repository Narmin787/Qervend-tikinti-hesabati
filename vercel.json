{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "public",
  "framework": null,
  "github": { "enabled": true, "silent": false },
  "redirects": [
    { "source": "/k", "destination": "/k/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/k/", "destination": "/kommunalhesabat/index.html" },
    { "source": "/k/:path*", "destination": "/kommunalhesabat/:path*" }
  ],
  "headers": [
    {
      "source": "/narminreportwebapp/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    }
  ]
}
